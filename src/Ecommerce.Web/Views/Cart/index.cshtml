@model IEnumerable<Ecommerce.Web.ViewModels.CartItemViewModel>

@{
    ViewData["Title"] = "Seu Carrinho";
    decimal total = Model.Sum(x => x.Price);
}

<style>
    .cart-container {
        background: linear-gradient(145deg, #1a1025 0%, #160a21 100%);
        border: 1px solid rgba(138, 43, 226, 0.2);
        border-radius: 8px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

    .cart-table th {
        color: #c77dff;
        border-bottom: 1px solid rgba(138, 43, 226, 0.3);
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 1px;
    }

    .cart-table td {
        color: #e0e0e0;
        vertical-align: middle;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .cart-item-img {
        width: 60px;
        height: 60px;
        object-fit: cover;
        border-radius: 4px;
        border: 1px solid #5a2e98;
    }

    .total-area {
        background-color: rgba(0, 0, 0, 0.3);
        border-top: 2px solid #00e6b8;
        border-radius: 0 0 8px 8px;
    }

    .checkout-btn {
        background: linear-gradient(90deg, #00b38f 0%, #00e6b8 100%);
        color: #0f0a18;
        border: none;
        padding: 12px 30px;
        font-weight: 900;
        text-transform: uppercase;
        transition: filter 0.2s;
    }

    .checkout-btn:hover {
        filter: brightness(1.2);
    }
</style>

<div class="container mt-5 mb-5">
    <h2 class="text-white mb-4"><i class="bi bi-cart3" style="color: #c77dff;"></i> Revisão do Pedido</h2>

    <div class="cart-container d-flex flex-column">
        @if (!Model.Any()) {
            <div class="p-5 text-center text-secondary">
                <i class="bi bi-emoji-frown fs-1"></i>
                <h4 class="mt-3">O seu carrinho está vazio.</h4>
                <a asp-controller="Catalog" asp-action="Index" class="btn btn-outline-light mt-3">Voltar à Loja</a>
            </div>
        } else {
            <div class="p-4 table-responsive">
                <table class="table table-borderless cart-table mb-0">
                    <thead>
                        <tr>
                            <th>Produto</th>
                            <th>Plataforma</th>
                            <th class="text-end">Preço</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model) {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="@item.ImageUrl" class="cart-item-img" />
                                        <span class="fw-bold">@item.ProductName</span>
                                    </div>
                                </td>
                                <td><span class="badge" style="background-color: rgba(138, 43, 226, 0.2); border: 1px solid #5a2e98;">@item.PlatformName</span></td>
                                <td class="text-end fw-bold text-white">R$ @item.Price.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="total-area p-4 d-flex justify-content-between align-items-center mt-auto">
                <div>
                    <span class="text-secondary text-uppercase d-block" style="font-size: 0.8rem;">Total a pagar</span>
                    <span class="fs-3 fw-bold" style="color: #00e6b8;">R$ @total.ToString("N2")</span>
                </div>
                
                <form asp-controller="Checkout" asp-action="Process" method="post">
                    <button type="submit" class="btn checkout-btn rounded">
                        <i class="bi bi-lightning-charge-fill"></i> Finalizar Compra
                    </button>
                </form>
            </div>
        }
    </div>
</div>