@model IEnumerable<Ecommerce.Web.ViewModels.ProductCardViewModel>

@{
    ViewData["Title"] = "Catálogo de Jogos";
}

<style>
    body {
        background-color: #0f0a18; 
        color: #e0e0e0;
    }

    .catalog-header {
        color: #d4bfff;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        border-bottom: 1px solid rgba(138, 43, 226, 0.3);
        padding-bottom: 10px;
        margin-bottom: 30px;
        margin-top: 20px;
    }

    /* O Cartão do Jogo */
    .game-card {
        background: linear-gradient(145deg, #1a1025 0%, #24143d 100%);
        border: 1px solid rgba(138, 43, 226, 0.1);
        border-radius: 4px; /* Bordas menos arredondadas dão um ar mais "Steam" */
        overflow: hidden;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s;
        height: 100%;
        box-shadow: 0 4px 6px rgba(0,0,0,0.5);
    }

    /* Efeito ao passar o mouse */
    .game-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 20px rgba(138, 43, 226, 0.3);
        border-color: rgba(138, 43, 226, 0.5);
        cursor: pointer;
    }

    /* Imagem de Capa do Jogo */
    .game-img {
        width: 100%;
        height: 180px;
        object-fit: cover;
        border-bottom: 2px solid #5a2e98;
    }

    .game-title {
        font-size: 1.15rem;
        font-weight: 700;
        color: #ffffff;
        margin-bottom: 2px;
    }

    .game-category {
        font-size: 0.75rem;
        color: #9d4edd;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* Tags de Plataforma (PC, Switch) */
    .platform-badge {
        background-color: rgba(157, 78, 221, 0.15);
        color: #c77dff;
        font-size: 0.7rem;
        padding: 4px 8px;
        border-radius: 3px;
        margin-right: 6px;
        border: 1px solid rgba(157, 78, 221, 0.3);
    }

    /* Área do Preço e Botão */
    .price-area {
        background-color: rgba(0, 0, 0, 0.2);
        padding: 10px 15px;
        border-top: 1px solid rgba(255,255,255,0.02);
    }

    .price-label {
        font-size: 0.65rem;
        color: #8b8b8b;
        text-transform: uppercase;
    }

    .price-tag {
        font-size: 1.1rem;
        font-weight: bold;
        color: #00e6b8; /* Verde/Ciano neon para dar um contraste forte com o roxo */
    }

    .buy-btn {
        background: linear-gradient(90deg, #7b2cbf 0%, #5a189a 100%);
        color: white;
        border: none;
        border-radius: 3px;
        padding: 6px 16px;
        font-size: 0.85rem;
        font-weight: bold;
        transition: filter 0.2s;
    }

    .buy-btn:hover {
        filter: brightness(1.2);
        color: white;
    }
</style>

<div class="container pb-5">
    <h3 class="catalog-header"><i class="bi bi-controller"></i> Destaques e Recomendados</h3>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
        @foreach (var game in Model)
        {
            <div class="col">
                <div class="game-card d-flex flex-column">
                    <img src="@game.ImageUrl" alt="@game.Name" class="game-img" />
                    
                    <div class="p-3 d-flex flex-column flex-grow-1">
                        <h4 class="game-title">@game.Name</h4>
                        <span class="game-category">@game.CategoryName</span>

                        <div class="mt-3 mb-2">
                            @foreach (var platform in game.Platforms)
                            {
                                <span class="platform-badge">@platform</span>
                            }
                        </div>
                    </div>

                    <div class="price-area mt-auto d-flex justify-content-between align-items-center">
                        <div class="d-flex flex-column">
                            <span class="price-label">A partir de</span>
                            <span class="price-tag">R$ @game.LowestPrice.ToString("N2")</span>
                        </div>
                        <button class="buy-btn">Ver Edições</button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>